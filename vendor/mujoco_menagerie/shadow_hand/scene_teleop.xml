<mujoco model="viture_teleop_scene">
  <!-- Reuse Menagerie Shadow Hand definitions for both hands. -->
  <include file="right_hand.xml"/>
  <include file="left_hand_prefixed.xml"/>

  <statistic extent="0.7" center="0 0.20 0.05"/>

  <visual>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="8192"/>
    <!-- 270/-15 = behind the scene at user-eye level, looking +Y "into" the
         work volume so reaching forward in real life maps to extending the
         rendered hands deeper into view. -->
    <global azimuth="270" elevation="-15"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
      rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="skel_rh_mat" rgba="1.0 0.9 0.2 0.75"/>
    <material name="skel_rh_wrist_mat" rgba="1.0 0.4 0.2 0.9"/>
    <material name="skel_lh_mat" rgba="0.4 0.9 1.0 0.75"/>
    <material name="skel_lh_wrist_mat" rgba="0.2 0.6 1.0 0.9"/>
    <material name="target_object_mat" rgba="0.5 0.7 0.5 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1"/>
    <light pos="0.3 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" pos="0 0 -0.1" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Graspable test object centered between the hands. -->
    <body name="target_object" pos="0.0 0 0.05">
      <freejoint/>
      <geom type="ellipsoid" size="0.03 0.04 0.02" material="target_object_mat"
        condim="6" priority="1" friction="0.5 0.01 0.003"/>
    </body>

